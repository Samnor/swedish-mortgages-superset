environment               = "dev"
vpc_id                    = "vpc-xxxxxxxx"
public_subnet_ids         = ["subnet-public-a", "subnet-public-b"]
private_subnet_ids        = ["subnet-private-a", "subnet-private-b"]
assign_public_ip          = true
internal_alb              = true
allowed_ingress_cidrs     = []
tailscale_proxy_enabled   = true
tailscale_auth_key_ssm_parameter_name = "/swedish-mortgages/dev/tailscale/auth-key"
tailscale_hostname        = "swedish-mortgages-dev-superset"
tailscale_proxy_subnet_id = "subnet-public-a"
athena_schema             = "swedish_mortgages_dev_marts"
athena_s3_staging_dir     = "s3://athena-queries-funfun/swedish-mortgages/dev/athena-results/"
athena_results_bucket_arn = "arn:aws:s3:::athena-queries-funfun"
data_lake_bucket_arn      = "arn:aws:s3:::dbt-data-lake-642948445774"
manage_db_master_password = true
